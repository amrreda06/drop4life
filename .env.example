# Django (Render / production)
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=your-app.onrender.com,127.0.0.1
CORS_ALLOWED_ORIGINS=https://amrreda06.github.io
CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com,https://amrreda06.github.io
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true

# PostgreSQL on Render (auto-injected as DATABASE_URL)
# DATABASE_URL=postgres://...

# Superadmin default password (first boot only)
DROP4LIFE_SUPERADMIN_PASSWORD=a1234!

# Render auto-injects this — do not set manually unless needed
# RENDER_EXTERNAL_HOSTNAME=your-service.onrender.com
